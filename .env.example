# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Public base URL — used to build share links (optional, auto-detected if omitted)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Secret for protecting the /api/cron/prune endpoint (required in production)
# Generate with: openssl rand -hex 32
# Vercel Cron sends it as: Authorization: Bearer <value>
CRON_SECRET=
