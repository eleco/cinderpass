{
  "name": "cinderpass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-prisma-status.mjs",
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && vitest run && next build",
    "db:status": "prisma migrate status",
    "db:migrate": "prisma migrate deploy",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "clsx": "^2.1.1",
    "next": "16.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^4.1.4",
    "prisma": "^6.6.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
